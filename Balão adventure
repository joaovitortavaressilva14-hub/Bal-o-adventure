<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Balão Adventure Turbo</title>
    <style>
        body { margin: 0; overflow: hidden; background-color: #fff; touch-action: none; }
        canvas { display: block; }
        #ui { position: absolute; top: 10px; left: 20px; font-family: sans-serif; font-size: 24px; color: #333; pointer-events: none; }
    </style>
</head>
<body>

    <div id="ui">Pontos: <span id="score">0</span></div>
    <canvas id="gameCanvas"></canvas>

<script>
    const canvas = document.getElementById('gameCanvas');
    const ctx = canvas.getContext('2d');
    const scoreElement = document.getElementById('score');

    canvas.width = window.innerWidth;
    canvas.height = window.innerHeight;

    let score = 0;
    let gameActive = true;
    let frameCount = 0;
    
    // --- A MÁGICA DA VELOCIDADE ---
    let gameSpeed = 4; // Velocidade inicial
    let speedIncrement = 0.2; // Quanto aumenta a cada nível

    const player = {
        x: canvas.width / 2,
        y: canvas.height * 0.7,
        width: 30,
        height: 45,
        targetX: canvas.width / 2
    };

    let obstacles = [];
    let items = [];

    // Movimentação suave pelo dedo/mouse
    const move = (e) => {
        let x = e.touches ? e.touches[0].clientX : e.clientX;
        player.targetX = x - player.width / 2;
    };
    window.addEventListener('mousemove', move);
    window.addEventListener('touchstart', move);
    window.addEventListener('touchmove', move);

    function createObstacle() {
        const width = Math.random() * (canvas.width * 0.4) + 60;
        const x = Math.random() * (canvas.width - width);
        obstacles.push({ x, y: -40, width, height: 12 });
    }

    function createItem() {
        const x = Math.random() * (canvas.width - 20);
        items.push({ x, y: -20, radius: 10 });
    }

    function update() {
        if (!gameActive) return;

        // Movimento suave do balão
        player.x += (player.targetX - player.x) * 0.18;

        frameCount++;
        // Ajusta o surgimento de itens conforme a velocidade
        if (frameCount % Math.max(20, Math.floor(80 - gameSpeed)) === 0) createObstacle();
        if (frameCount % 50 === 0) createItem();

        // Atualiza Obstáculos
        obstacles.forEach((obs, i) => {
            obs.y += gameSpeed; // Usa a velocidade variável
            if (player.x < obs.x + obs.width && player.x + player.width > obs.x &&
                player.y < obs.y + obs.height && player.y + player.height > obs.y) {
                gameOver();
            }
            if (obs.y > canvas.height) obstacles.splice(i, 1);
        });

        // Atualiza Itens
        items.forEach((item, i) => {
            item.y += gameSpeed;
            const dist = Math.hypot((player.x + 15) - item.x, (player.y + 20) - item.y);
            if (dist < 25) {
                score++;
                scoreElement.innerText = score;
                items.splice(i, 1);
                
                // --- ACELERAÇÃO ---
                // A cada 5 pontos, o jogo fica mais rápido!
                if (score % 5 === 0) {
                    gameSpeed += speedIncrement;
                    console.log("Velocidade atual:", gameSpeed);
                }
            }
            if (item.y > canvas.height) items.splice(i, 1);
        });
    }

    function draw() {
        ctx.clearRect(0, 0, canvas.width, canvas.height);

        // Desenhar Balão
        ctx.fillStyle = "#666";
        ctx.beginPath();
        ctx.ellipse(player.x + 15, player.y + 15, 15, 18, 0, 0, Math.PI*2);
        ctx.fill();
        ctx.fillStyle = "#333";
        ctx.fillRect(player.x + 10, player.y + 35, 10, 8);

        // Desenhar Blocos com Espinhos (Visual do vídeo)
        obstacles.forEach(obs => {
            ctx.fillStyle = "#222";
            ctx.fillRect(obs.x, obs.y, obs.width, obs.height);
            for(let i=0; i<obs.width; i+=10) {
                ctx.beginPath();
                ctx.moveTo(obs.x + i, obs.y + obs.height);
                ctx.lineTo(obs.x + i + 5, obs.y + obs.height + 8);
                ctx.lineTo(obs.x + i + 10, obs.y + obs.height);
                ctx.fill();
            }
        });

        // Desenhar Moedas/Bolinhas
        items.forEach(item => {
            ctx.strokeStyle = "#333";
            ctx.lineWidth = 2;
            ctx.beginPath();
            ctx.arc(item.x, item.y, item.radius, 0, Math.PI*2);
            ctx.stroke();
        });
    }

    function gameOver() {
        gameActive = false;
        alert("PERDEU! Pontuação: " + score);
        location.reload();
    }

    function loop() {
        update();
        draw();
        requestAnimationFrame(loop);
    }
    loop();
</script>
</body>
</html>
